import time

def timer(func):
    def wrapper(*args, **kwargs): #accept any number of positional and keyword arguments 

        start=time.time()

        result=func(*args, **kwargs) #call the original function with the provided arguments and store the result

        end=time.time()

        print(f"execution time: {end-start} seconds")

        return result 
    return wrapper


@timer

def predict(data):
    print("predicting....")

    time.sleep(2) 
    return "predicted result"

